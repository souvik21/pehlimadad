pehlimadad/web/.next/
pehlimadad/web/out/

.claude/
pehlimadad/web/scripts/gen-og.js

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
